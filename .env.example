# ============================================================
# Pepper AI — Environment Variables  v3.0
# ============================================================
# Copy this to .env for local development:
#   cp .env.example .env
# Then fill in all values.
# NEVER commit .env to git.
# ============================================================

# ── Required: Flask Security ──────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_client_secret_here

# ── Required: Google OAuth ────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Authorized redirect URIs: https://yourdomain.com/oauth/callback
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# ── Required: Your Deployed App URL ───────────────────────────
# Local: http://localhost:5000
# Railway: https://your-app.up.railway.app
APP_URL=http://localhost:5000

# ── Required: Gemini AI (for metadata generation) ─────────────
# Create at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# ── Optional: Database (defaults to SQLite) ───────────────────
# Leave empty for SQLite (default)
# For PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ── Optional: File Upload Limit ───────────────────────────────
# Default: 10GB (in bytes)
MAX_CONTENT_LENGTH=10737418240

# ── Optional: Flask Debug (NEVER enable in production) ────────
FLASK_DEBUG=0

# ── Optional: OAuth Transport ─────────────────────────────────
# Set to 0 in production (Railway auto-uses HTTPS)
# Set to 1 only for local development without HTTPS
ALLOW_HTTP_OAUTH=1

# ── Optional: Server Port ─────────────────────────────────────
# Railway sets $PORT automatically — do not change unless needed
PORT=5000

# ============================================================
# Railway Volume Setup (CRITICAL for multi-device sync)
# ============================================================
# 1. In Railway dashboard: New → Volume
# 2. Mount path: /home/user/pepperai/instance
# 3. This ensures SQLite DB persists across deploys and devices
# ============================================================

# ============================================================
# Google Cloud Setup Checklist
# ============================================================
# 1. Go to https://console.cloud.google.com
# 2. Create project "Pepper AI"
# 3. Enable APIs:
#    - YouTube Data API v3
#    - YouTube Analytics API
#    - Google OAuth2 API
#    - Google+ API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add Authorized Redirect URI:
#    https://your-app.up.railway.app/oauth/callback
# 6. Download client JSON and extract client_id + client_secret
# ============================================================
